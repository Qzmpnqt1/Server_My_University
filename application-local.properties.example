# Скопируйте в application-local.properties (в корне Server_My_University, рядом с gradlew.bat)
# и укажите реальный пароль от MySQL на вашем ПК.
#
# Затем просто запускайте:  .\gradlew.bat bootRun
# (Gradle сам включит профиль "local", если файл application-local.properties существует.)
#
# Частые случаи:
# - MySQL из docker-compose: на хосте порт 3307 (см. MYSQL_HOST_PORT в compose), пароль root
# - Свой MySQL на стандартном 3306: URL с localhost:3306
# - XAMPP: часто пустой пароль — spring.datasource.password=

spring.datasource.url=jdbc:mysql://localhost:3307/my_university?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_unicode_ci
spring.datasource.username=root
spring.datasource.password=root
